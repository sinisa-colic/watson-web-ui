{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist-server"
  },
  "include": ["server/**/*.ts", "integrations/**/*.ts"],
  "exclude": [
    "integrations/**/client.ts",
    "integrations/client-manifest.ts",
    "integrations/client-selection.ts",
    "integrations/unified-days.ts"
  ]
}
