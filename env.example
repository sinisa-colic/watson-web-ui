# Watson Web UI - copy to .env and fill in values

# Optional: app bind settings for npm start
# HOST=0.0.0.0
# PORT=3131

# Optional: HTTPS for phone/PWA service worker support.
# Enable explicitly; otherwise npm start and npm run dev:web remain plain HTTP.
# SSL_ENABLED=true
# SSL_DOMAIN=your-domain.example
# Linux certbot default:
# SSL_CERT_PATH=/etc/letsencrypt/live/your-domain.example/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/your-domain.example/privkey.pem
# macOS / custom certbot config_dir (set both paths if not under /etc/letsencrypt):
# SSL_CERT_PATH=/path/to/fullchain.pem
# SSL_KEY_PATH=/path/to/privkey.pem

# Optional: dev-only Vite server settings for npm run dev.
# When SSL_ENABLED=true, dev:web uses the same cert/key and proxies API calls over HTTPS.
# WEB_HOST=0.0.0.0
# WEB_PORT=5173
# API_PROXY_HOST=127.0.0.1

# Optional: Jira Cloud integration (read-only issue titles)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_read_only_api_token

# Optional: override default JQL for "my tasks" picker
# JIRA_JQL=assignee=currentUser() AND statusCategory != Done ORDER BY updated DESC

# Optional: multi-client setup (copy clients.config.example.ts to clients.config.ts)
# WATSON_DEFAULT_CLIENT=client-a
#
# CLIENT_A_KEY=client-a
# CLIENT_A_LABEL=Client A
# CLIENT_A_WATSON_TAG=client-a
# CLIENT_A_JIRA_BASE_URL=https://client-a.atlassian.net
# CLIENT_A_JIRA_EMAIL=you@example.com
# CLIENT_A_JIRA_API_TOKEN=your_read_only_api_token
# CLIENT_A_JIRA_JQL=assignee=currentUser() AND statusCategory != Done ORDER BY updated DESC
#
# CLIENT_B_KEY=client-b
# CLIENT_B_LABEL=Client B
# CLIENT_B_WATSON_TAG=client-b
# CLIENT_B_JIRA_BASE_URL=https://client-b.atlassian.net
# CLIENT_B_JIRA_EMAIL=you@example.com
# CLIENT_B_JIRA_API_TOKEN=another_read_only_api_token
# CLIENT_B_JIRA_JQL=assignee=currentUser() AND statusCategory != Done ORDER BY updated DESC
